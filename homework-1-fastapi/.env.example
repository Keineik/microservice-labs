# Copy to .env for local (non-Docker) runs. NEVER commit a real .env.
# All app config is read from env vars via pydantic-settings (prefix APP_).

# SQLAlchemy async URL (asyncpg driver). For docker-compose this is set to the
# "postgres" service host; for local runs point it at localhost.
APP_DATABASE_URL=postgresql+asyncpg://app:app@localhost:5432/enrollment

APP_LOG_LEVEL=INFO
APP_DB_ECHO=false
APP_API_V1_PREFIX=/api/v1
